# Copy to .env and fill in. NEVER commit .env.

# --- Data source: Yahoo Finance (no API key required) ---
# Optional tuning overrides:
NASDAQ_LIST_URL=https://www.nasdaqtrader.com/dynamic/SymDir/nasdaqlisted.txt
HISTORY_PERIOD=1y
YF_BATCH_SIZE=200
MAX_PREFILTER=800
MAX_ENRICH=250

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TO=
EMAIL_FROM=

# --- Behaviour ---
SCAN_MODE=tight          # "tight" or "loose"
LOG_LEVEL=INFO

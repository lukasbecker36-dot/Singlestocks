# Copy to .env and fill in. NEVER commit .env.

# --- Data source ---
FMP_API_KEY=
# Optional overrides
FMP_BASE_URL=https://financialmodelingprep.com/api/v3
FMP_MAX_CALLS_PER_DAY=250
FMP_MIN_INTERVAL_SECONDS=0.3
SCREEN_LIMIT=60
CACHE_DIR=cache

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TO=
EMAIL_FROM=

# --- Behaviour ---
SCAN_MODE=tight          # "tight" or "loose"
LOG_LEVEL=INFO
